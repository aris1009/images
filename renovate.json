{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "minimumReleaseAge": "4 days",
  "prHourlyLimit": 3,
  "prConcurrentLimit": 15,
  "dependencyDashboard": true,
  "platformAutomerge": true,
  "customManagers": [
    {
      "customType": "regex",
      "description": "xcaddy --with <module>@<version> in Dockerfiles",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": [
        "--with\\s+(?<depName>github\\.com/[^@\\s]+)@(?<currentValue>v[\\d.]+(?:[-+][\\w.]+)?)"
      ],
      "datasourceTemplate": "go"
    },
    {
      "customType": "regex",
      "description": "Per-image upstream VERSION file (annotated with # renovate: datasource=... depName=...)",
      "managerFilePatterns": ["/(^|/)VERSION$/"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)(?:\\s+versioning=(?<versioning>\\S+))?\\s*\\n(?<currentValue>\\S+)"
      ]
    }
  ],
  "packageRules": [
    {
      "description": "Auto-merge patch/minor/digest bumps after CI green",
      "matchUpdateTypes": ["patch", "minor", "pin", "digest"],
      "automerge": true
    },
    {
      "description": "Major upgrades require manual review",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}
